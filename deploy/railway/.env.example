# ---------------------------------------------------------------------------
# kuhl-haus — Railway provisioning environment
#
# Copy this file to your local shell (e.g. `set -a; source .env; set +a`)
# before running `python3 deploy/railway/provision.py`.
# NEVER commit a populated copy of this file to git.
# ---------------------------------------------------------------------------

# --- Railway access --------------------------------------------------------
# Account/team API token: https://railway.app/account/tokens
RAILWAY_TOKEN=

# Existing project id to update in place (leave empty on the very first run
# to create a fresh project; provision.py will print the new id).
RAILWAY_PROJECT_ID=

# Optional — only used when RAILWAY_PROJECT_ID is empty (creates a new project
# with this name) and to pick the target environment for variable upserts.
RAILWAY_PROJECT_NAME=kuhl-haus
RAILWAY_ENVIRONMENT=production

# --- Third-party API keys (required by the data services) ------------------
MASSIVE_API_KEY=
FINLIGHT_API_KEY=

# Optional: enables the Databento fallback inside the MDL listener.
# Omit to keep the original Massive-only behaviour.
DATABENTO_API_KEY=

# --- Internal service credentials ------------------------------------------
# Shared between the wds server and the scp app (must match on both sides).
# Generate a strong value with: openssl rand -hex 32
WDS_API_KEY=

# Infrastructure credentials. Used to construct the RABBITMQ_URL connection
# string injected into mdl / mdp / fdl / fdp.
REDIS_PASSWORD=redis
RABBITMQ_USER=mdq
RABBITMQ_PASSWORD=mdq
