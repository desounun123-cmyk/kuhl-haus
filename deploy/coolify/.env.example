# ---------------------------------------------------------------------------
# kuhl-haus — Coolify environment variables
# Copy these into Coolify > your application > Environment Variables.
# Do NOT commit real values to git.
# ---------------------------------------------------------------------------

# --- Public domain for the py4web app (scp service, port 8000) -------------
# Coolify will auto-issue a Let's Encrypt cert for this host.
# Example: SERVICE_FQDN_SCP_8000=https://app.example.com
SERVICE_FQDN_SCP_8000=

# --- Required third-party API keys -----------------------------------------
MASSIVE_API_KEY=
FINLIGHT_API_KEY=

# --- Internal service auth -------------------------------------------------
# Shared between the `wds` server and the `scp` app. Generate with:
#   openssl rand -hex 32
WDS_API_KEY=

# --- Infrastructure credentials --------------------------------------------
REDIS_PASSWORD=redis
RABBITMQ_USER=mdq
RABBITMQ_PASSWORD=mdq
